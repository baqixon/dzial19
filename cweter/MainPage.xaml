<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="cweter.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Rezerwacja wizyty u lekarza" FontSize="24" HorizontalOptions="Center" />
            <Picker x:Name="specjalizacjaPicker" Title="Wybierz specjalizację">

                <Picker.Items>
                    <x:String>Internista</x:String>
                    <x:String>Kardiolog</x:String>
                    <x:String>Dermatolog</x:String>
                    <x:String>Okulista</x:String>
                </Picker.Items>

            </Picker>
            <VerticalStackLayout HorizontalOptions="Center">
            <DatePicker x:Name="dataPicker" />
            <TimePicker x:Name="godzinaPicker" Time="08:00"/>
            <Button Text="Zarezerwuj" Clicked="OnReserveClicked" />
            </VerticalStackLayout>
        </VerticalStackLayout>
        
    </ScrollView>

</ContentPage>
